APP_NAME=kb-platform
APP_ENV=local
APP_VERSION=0.1.0
API_V1_PREFIX=/api/v1
LOG_LEVEL=INFO

POSTGRES_DB=kb_platform
POSTGRES_USER=kb_platform
POSTGRES_PASSWORD=kb_platform
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://kb_platform:kb_platform@localhost:5432/kb_platform

REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_URL=http://localhost:6333

MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ENDPOINT_URL=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=kb-platform

PROMETHEUS_METRICS_ENABLED=true
DEPENDENCY_HEALTH_CHECKS_ENABLED=true
DEPENDENCY_HEALTH_TIMEOUT_SECONDS=2.0
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

JWT_SECRET_KEY=change-me-in-production-with-at-least-32-bytes
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
DEFAULT_API_KEY_RATE_LIMIT=100
