APP_NAME=byob
APP_ENV=local
APP_VERSION=0.1.0
API_V1_PREFIX=/api/v1
LOG_LEVEL=INFO
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_MINIO_CONSOLE_URL=http://localhost:9001
NEXT_PUBLIC_QDRANT_DASHBOARD_URL=http://localhost:6333/dashboard

POSTGRES_DB=byob
POSTGRES_USER=byob
POSTGRES_PASSWORD=byob
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://byob:byob@localhost:5432/byob

REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_URL=http://localhost:6333

MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ENDPOINT_URL=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=byob

INFINITY_IMAGE=michaelf34/infinity:latest-cpu

EMBEDDING_PORT=7997
EMBEDDING_ENDPOINT_URL=http://localhost:7997
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIMENSION=1024

PDF_PARSER=mineru
MINERU_COMMAND=mineru
MINERU_BACKEND=pipeline
MINERU_PARSE_METHOD=auto
MINERU_LANG=ch
MINERU_TIMEOUT_SECONDS=900
# MINERU_API_URL=http://127.0.0.1:8000
MINERU_FORMULA_ENABLE=true
MINERU_TABLE_ENABLE=true
MINERU_FALLBACK_TO_PYPDF=true
RERANK_PORT=7998
RERANK_ENDPOINT_URL=http://localhost:7998
RERANK_MODEL=BAAI/bge-reranker-base
RERANK_ENABLED=true
RETRIEVAL_CACHE_TTL_SECONDS=300

MCP_SERVER_URL=http://127.0.0.1:8010/mcp
MCP_CLIENT_TIMEOUT_SECONDS=60

# Optional OpenAI-compatible chat endpoint for the console QA Agent.
# AGENT_LLM_ENDPOINT_URL=http://localhost:11434/v1
# AGENT_LLM_API_KEY=
AGENT_LLM_MODEL=qwen2.5:7b-instruct
AGENT_LLM_TIMEOUT_SECONDS=60
AGENT_MAX_CONTEXT_CHARS=12000
AGENT_MAX_IMAGE_ASSETS=3
AGENT_MAX_IMAGE_BYTES=2000000

CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

PROMETHEUS_METRICS_ENABLED=true
DEPENDENCY_HEALTH_CHECKS_ENABLED=true
DEPENDENCY_HEALTH_TIMEOUT_SECONDS=2.0
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

JWT_SECRET_KEY=change-me-in-production-with-at-least-32-bytes
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
DEFAULT_API_KEY_RATE_LIMIT=100

# Optional one-time admin bootstrap settings for `python -m api.scripts.seed_admin`.
BYOB_ADMIN_EMAIL=admin@example.com
BYOB_TENANT_NAME=Default Tenant
# BYOB_ADMIN_PASSWORD is intentionally omitted; set it in your shell or let the script generate one.
# BYOB_ADMIN_RESET_PASSWORD=false
