APP_NAME=byob
APP_ENV=local
APP_VERSION=0.1.0
API_V1_PREFIX=/api/v1
LOG_LEVEL=INFO

POSTGRES_DB=byob
POSTGRES_USER=byob
POSTGRES_PASSWORD=byob
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://byob:byob@localhost:5432/byob

REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_URL=http://localhost:6333

MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ENDPOINT_URL=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=byob

EMBEDDING_ENDPOINT_URL=http://localhost:7997
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIMENSION=1024
RERANK_ENDPOINT_URL=http://localhost:7998
RERANK_MODEL=BAAI/bge-reranker-v2-m3
RERANK_ENABLED=false
RETRIEVAL_CACHE_TTL_SECONDS=300
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

PROMETHEUS_METRICS_ENABLED=true
DEPENDENCY_HEALTH_CHECKS_ENABLED=true
DEPENDENCY_HEALTH_TIMEOUT_SECONDS=2.0
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

JWT_SECRET_KEY=change-me-in-production-with-at-least-32-bytes
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
DEFAULT_API_KEY_RATE_LIMIT=100
